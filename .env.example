# RTM API credentials
# Get your API key at: https://www.rememberthemilk.com/services/api/keys.rtm
RTM_API_KEY=your_api_key_here
RTM_SHARED_SECRET=your_shared_secret_here

# Pre-authenticated RTM token
# Run: npm run auth (see README)
RTM_AUTH_TOKEN=your_auth_token_here

# Supabase
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Service role key for server-side operations
# Only needed if you want to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: Database schema (default: public)
# Set to 'milkpm' to use a dedicated schema (recommended for shared databases)
# See supabase/schema.sql for setup instructions
MILKPM_DB_SCHEMA=public
