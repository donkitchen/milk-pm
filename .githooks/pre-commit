#!/bin/bash
# Pre-commit hook to prevent committing secrets

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Checking for secrets..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Patterns that indicate secrets (case insensitive)
SECRET_PATTERNS=(
    'RTM_API_KEY=.{10,}'
    'RTM_SHARED_SECRET=.{10,}'
    'RTM_AUTH_TOKEN=.{10,}'
    'SUPABASE_SERVICE_ROLE_KEY=.{10,}'
    'SUPABASE_ANON_KEY=.{10,}'
    'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9'  # JWT token prefix
    'sk-[a-zA-Z0-9]{20,}'                      # OpenAI-style keys
    'ghp_[a-zA-Z0-9]{36}'                      # GitHub PAT
    'gho_[a-zA-Z0-9]{36}'                      # GitHub OAuth
    'github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}' # GitHub fine-grained PAT
)

# Files to always block
BLOCKED_FILES=(
    '.env'
    '.env.local'
    '.env.production'
    '.env.development'
)

FOUND_SECRETS=0

# Check for blocked files
for file in $STAGED_FILES; do
    filename=$(basename "$file")

    # Check if it's a blocked file pattern
    if [[ "$filename" == .env* && "$filename" != ".env.example" ]]; then
        echo -e "${RED}BLOCKED:${NC} $file (env file)"
        FOUND_SECRETS=1
    fi
done

# Check file contents for secret patterns
for file in $STAGED_FILES; do
    # Skip binary files and .env.example
    if [[ "$file" == *.env.example ]]; then
        continue
    fi

    # Get staged content
    CONTENT=$(git show ":$file" 2>/dev/null)

    for pattern in "${SECRET_PATTERNS[@]}"; do
        if echo "$CONTENT" | grep -qE "$pattern"; then
            echo -e "${RED}BLOCKED:${NC} $file contains potential secret matching: $pattern"
            FOUND_SECRETS=1
        fi
    done
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo -e "${YELLOW}Commit blocked to prevent leaking secrets.${NC}"
    echo "If this is a false positive, you can bypass with: git commit --no-verify"
    echo ""
    exit 1
fi

echo "No secrets detected."
exit 0
